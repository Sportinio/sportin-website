# ── REQUIRED ──────────────────────────────────────────────────────────
# GitHub fine-grained personal access token (read-only on the 3 repos).
GITHUB_TOKEN=github_pat_xxx

# GitHub org / owner name.
GITHUB_ORG=Sportinio

# Tracking repo holding one Issue per feature (label = FEATURE_LABEL).
FEATURES_REPO=mobile-features

# ── MOBILE REPO CONFIG (pick one mode) ────────────────────────────────
#
# MODE A — single repo containing both iOS and Android code:
MOBILE_REPO=rork-sportin-io
IOS_PATH=ios/
ANDROID_PATH=android/
#
# MODE B — separate iOS and Android repos (comment out MOBILE_REPO above
# and uncomment these two instead):
# IOS_REPO=ios-app
# ANDROID_REPO=android-app

# ── OPTIONAL ──────────────────────────────────────────────────────────
# Label that marks a tracking issue. Default: "feature".
FEATURE_LABEL=feature

# Warn when iOS is ahead of Android by more than this. Default: 3.
IOS_AHEAD_LIMIT=3

# Basic auth gate (recommended for any public URL).
BASIC_AUTH_USER=sportin
BASIC_AUTH_PASS=replace-with-long-random-string
