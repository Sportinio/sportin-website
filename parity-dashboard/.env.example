# GitHub fine-grained personal access token.
# Required scopes (read-only): Contents: Read, Issues: Read, Pull requests: Read, Metadata: Read.
# Grant access to the 3 repos below.
GITHUB_TOKEN=ghp_xxx_yourfinetokenhere

# GitHub org name (case-sensitive).
GITHUB_ORG=Sportinio

# Repo holding the tracking issues (one issue per feature, labeled "feature").
FEATURES_REPO=mobile-features

# Mobile source repos.
IOS_REPO=ios-app
ANDROID_REPO=android-app

# Optional: label that marks a tracking issue as a "feature". Default: "feature".
FEATURE_LABEL=feature

# Optional: warn when iOS is ahead of Android by more than this. Default: 3.
IOS_AHEAD_LIMIT=3

# Basic auth gate (recommended for any public URL).
# Leave unset locally; set on Vercel for admin.sportin.io.
BASIC_AUTH_USER=sportin
BASIC_AUTH_PASS=replace-with-long-random-string
